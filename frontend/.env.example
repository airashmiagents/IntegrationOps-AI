# Optional: call API directly from the browser (must match backend port + CORS).
# Leave unset in dev to use same-origin ``/api`` + Vite proxy (recommended).
# VITE_API_URL=http://127.0.0.1:8000

# Where Vite proxies ``/api/*`` during ``npm run dev`` (match your uvicorn port).
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
