# --- Local dev (default): same-origin ``/api`` + Vite proxy — leave VITE_API_URL unset.
# Where Vite proxies ``/api/*`` during ``npm run dev`` (match your uvicorn port).
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# --- Vercel / production build: set in Vercel → Environment Variables (baked in at ``npm run build``).
# Your Render (or other) API origin, no trailing slash. Example:
# VITE_API_URL=https://integrationops-ai-api.onrender.com
