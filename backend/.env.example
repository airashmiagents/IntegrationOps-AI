# Example environment variables — copy to `.env` and fill in.

APP_NAME=IntegrationOps-AI
DEBUG=true
# Shown on the dashboard via GET /health (demo only — no email is sent).
# MOCK_ALERT_EMAIL=integrationops-alerts@demo.example.com
# Print step-by-step CPI + LLM narrative to stderr (prefixed [agent-trace]) during investigations and monitor cycles.
# AGENT_TERMINAL_TRACE=true

# Append-only SQLite: every LLM (and heuristic) exchange — system+user messages JSON, raw assistant text, response JSON.
# Default file: backend/llm_audit.sqlite (gitignored). Disable with LLM_AUDIT_SQLITE_ENABLED=false
# LLM_AUDIT_SQLITE_PATH=

# Autonomous monitor writes analyzed failures to SQLite (GET /incidents). Default: backend/incidents.sqlite
# INCIDENTS_SQLITE_ENABLED=false
# INCIDENTS_SQLITE_PATH=

# --- SAP CPI (OData — SAP Integration Content + MPL Swagger) ---
# When CPI_USE_MOCK=true, the agent uses realistic simulated logs/metadata (default for hackathons).
CPI_USE_MOCK=true
# Tenant host only (no /api/v1). Example: https://<account>-tmn.<region>.hana.ondemand.com
SAP_CPI_BASE_URL=https://your-tenant-tmn.eu1.hana.ondemand.com
SAP_CPI_USER=
SAP_CPI_PASSWORD=
# REST OData root for both MPL and Integration Content (default /api/v1 per SAP Swagger).
# SAP_CPI_API_ROOT=/api/v1
# Override full MPL path only if needed (legacy /http/v1/...).
# SAP_CPI_MPL_PATH=/http/v1/MessageProcessingLogs
# Override design-time root only if it differs from SAP_CPI_API_ROOT.
# SAP_CPI_DESIGNTIME_ODATA_ROOT=/api/v1

# Legacy OAuth placeholders (optional — not used by the starter OData client)
SAP_CPI_OAUTH_CLIENT_ID=
SAP_CPI_OAUTH_CLIENT_SECRET=

# --- Periodic CPI monitor (APScheduler) ---
# Requires CPI_USE_MOCK=false and valid CPI credentials. Polls FAILED MPL + design-time + LLM.
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_SEC=300
# Comma-separated IntegrationArtifact.Id values to watch (same as agent iflow_name).
MONITOR_IFLOW_IDS=
# MPL LogEnd lookback for FAILED rows (minutes).
SCHEDULER_LOOKBACK_MINUTES=15

# --- OpenRouter (defaults: distinct :free model ids — do not set FALLBACK to the same id as MODEL) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Different OpenRouter id than OPENROUTER_MODEL (same id = second attempt is skipped).
OPENROUTER_FALLBACK_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://localhost
# OPENROUTER_APP_TITLE=IntegrationOps-AI
# Extra POST retries per model after HTTP 429 (shared free tiers rate-limit often). 0 = no retries.
# OPENROUTER_429_EXTRA_ATTEMPTS=2

# Legacy aliases
LLM_API_KEY=
LLM_API_BASE_URL=
