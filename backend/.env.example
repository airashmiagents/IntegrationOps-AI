# Example environment variables — copy to `.env` and fill in.

APP_NAME=IntegrationOps-AI
DEBUG=true

# --- SAP CPI (OData monitoring) ---
# When CPI_USE_MOCK=true, the agent uses realistic simulated logs/metadata (default for hackathons).
CPI_USE_MOCK=true
SAP_CPI_BASE_URL=https://your-tenant.hci.sap.hana.ondemand.com
SAP_CPI_USER=
SAP_CPI_PASSWORD=
# If OData returns 404, set the path your tenant uses (see SAP CPI OData docs).
# SAP_CPI_MPL_PATH=/http/v1/MessageProcessingLogs

# Legacy OAuth placeholders (optional — not used by the starter OData client)
SAP_CPI_OAUTH_CLIENT_ID=
SAP_CPI_OAUTH_CLIENT_SECRET=

# --- OpenRouter (DeepSeek / Llama / etc.) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://localhost
# OPENROUTER_APP_TITLE=IntegrationOps-AI

# Legacy aliases
LLM_API_KEY=
LLM_API_BASE_URL=
